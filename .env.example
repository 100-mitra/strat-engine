# Copy to .env and adjust. All values have safe local-dev defaults in settings.py.

# Django
SECRET_KEY=dev-insecure-key-change-me
DEBUG=1
ALLOWED_HOSTS=*
# Comma-separated, e.g. https://stratengine.onrender.com
CSRF_TRUSTED_ORIGINS=

# Database. If unset, settings.py falls back to a local SQLite file (handy for a quick clone+test).
# docker-compose and CI set this to Postgres.
DATABASE_URL=postgres://stratengine:stratengine@db:5432/stratengine
